{
  "name": "glimpse-cli",
  "version": "0.2.2",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22.18.0",
    "bun": ">=1.3.14"
  },
  "bin": {
    "glimpse": "./dist/cli.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjesuiter/glimpse-cli.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsdown",
    "build:binary": "bun scripts/build-binaries.ts --current",
    "build:binaries": "bun scripts/build-binaries.ts",
    "prepack": "bun run build >/dev/null",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "start": "bun src/cli.ts"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "evlog": "^2.18.1",
    "glimpseui": "^0.8.1",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "^0.22.1",
    "typescript": "^5.9.3",
    "unrun": "^0.3.0"
  }
}
